{
  "name": "OpenHarness",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "assets:sync": "node tooling/workflows/assets/sync.cjs",
    "assets:sync:monaco": "node tooling/workflows/assets/sync.cjs monaco",
    "assets:sync:icons": "node tooling/workflows/assets/sync.cjs icons",
    "copy-monaco": "pnpm run assets:sync:monaco",
    "copy-icons": "pnpm run assets:sync:icons",
    "copy-assets": "pnpm run assets:sync",
    "version:write": "node tooling/workflows/version/write.cjs",
    "generate-version": "pnpm run version:write",
    "generate-all": "pnpm run version:write",
    "postinstall": "pnpm run assets:sync",
    "workspace:dev": "node tooling/workflows/dev/start.cjs web",
    "dev": "pnpm run workspace:dev",
    "dev:web": "pnpm --dir src/web-ui dev",
    "lint:web": "pnpm --dir src/web-ui run lint",
    "lint:web:fix": "pnpm --dir src/web-ui run lint:fix",
    "prebuild": "pnpm run prebuild:web",
    "prebuild:web": "pnpm run assets:sync --silent && pnpm run version:write --silent",
    "type-check:web": "pnpm --dir src/web-ui run type-check",
    "build": "pnpm run build:web",
    "verify:monaco-assets": "node scripts/verify-monaco-assets.cjs",
    "build:web": "pnpm run type-check:web && pnpm --dir src/web-ui build && pnpm run verify:monaco-assets",
    "build:mobile-web": "pnpm --dir src/mobile-web build",
    "prepare:mobile-web": "node tooling/workflows/mobile/build.cjs",
    "preview": "pnpm --dir src/web-ui preview",
    "desktop:workspace:build": "node tooling/workflows/mobile/build.cjs --install",
    "desktop:dev": "node tooling/workflows/dev/start.cjs desktop",
    "desktop:dev:raw": "cross-env-shell CI=true \"cd src/apps/desktop && tauri dev\"",
    "desktop:package": "node tooling/workflows/desktop/build.mjs",
    "desktop:build": "pnpm run desktop:package",
    "desktop:build:fast": "node tooling/workflows/desktop/build.mjs --debug --no-bundle",
    "desktop:build:release-fast": "node tooling/workflows/desktop/build.mjs --no-bundle -- --profile release-fast",
    "desktop:build:exe": "node tooling/workflows/desktop/build.mjs --no-bundle",
    "desktop:build:nsis": "node tooling/workflows/desktop/build.mjs --bundles nsis",
    "desktop:build:arm64": "node tooling/workflows/desktop/build.mjs --target aarch64-apple-darwin --bundles dmg",
    "desktop:build:x86_64": "node tooling/workflows/desktop/build.mjs --target x86_64-apple-darwin --bundles dmg",
    "desktop:build:linux": "node tooling/workflows/desktop/build.mjs",
    "desktop:build:linux:deb": "node tooling/workflows/desktop/build.mjs --bundles deb",
    "desktop:build:linux:rpm": "node tooling/workflows/desktop/build.mjs --bundles rpm",
    "desktop:build:linux:appimage": "node tooling/workflows/desktop/build.mjs --bundles appimage",
    "installer:build": "pnpm --dir OpenHarness-Installer run installer:build",
    "installer:build:fast": "pnpm --dir OpenHarness-Installer run installer:build:fast",
    "installer:build:only": "pnpm --dir OpenHarness-Installer run installer:build:only",
    "installer:build:only:fast": "pnpm --dir OpenHarness-Installer run installer:build:only:fast",
    "installer:dev": "pnpm --dir OpenHarness-Installer run installer:dev",
    "cli:dev": "cd src/apps/cli && cargo run --",
    "cli:build": "cd src/apps/cli && cargo build --release",
    "cli:run": "cd src/apps/cli && cargo run --release --",
    "cli:exec": "cd src/apps/cli && cargo run -- exec",
    "cli:check": "cd src/apps/cli && cargo check",
    "cli:test": "cd src/apps/cli && cargo test",
    "preview-components": "pnpm --dir src/web-ui exec vite --config vite.config.preview.ts",
    "build-components": "pnpm --dir src/web-ui exec vite build --config vite.config.preview.ts",
    "website:dev": "pnpm --dir website run dev",
    "website:build": "pnpm --dir website run build",
    "website:preview": "pnpm --dir website run preview",
    "website:install": "pnpm --dir website install",
    "e2e:install": "pnpm --dir tests/e2e install",
    "e2e:test": "cross-env OPENHARNESS_E2E_APP_MODE=debug pnpm --dir tests/e2e test",
    "e2e:test:l0": "cross-env OPENHARNESS_E2E_APP_MODE=debug pnpm --dir tests/e2e run test:l0",
    "e2e:test:l0:all": "cross-env OPENHARNESS_E2E_APP_MODE=debug pnpm --dir tests/e2e run test:l0:all",
    "e2e:test:l1": "cross-env OPENHARNESS_E2E_APP_MODE=debug pnpm --dir tests/e2e run test:l1",
    "e2e:test:smoke": "cross-env OPENHARNESS_E2E_APP_MODE=debug pnpm --dir tests/e2e run test:smoke",
    "e2e:test:chat": "cross-env OPENHARNESS_E2E_APP_MODE=debug pnpm --dir tests/e2e run test:chat"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@vitejs/plugin-react": "^4.6.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "sass": "^1.99.0",
    "sharp": "^0.34.3",
    "typescript": "~5.8.3",
    "vite": "^7.3.2"
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b",
  "pnpm": {
    "overrides": {
      "anymatch>picomatch": "2.3.2",
      "archiver-utils>lodash": "4.18.1",
      "basic-ftp": "5.3.0",
      "copyfiles>minimatch": "3.1.4",
      "dompurify": "3.4.0",
      "edgedriver>fast-xml-parser": "5.7.1",
      "glob@7.2.3>minimatch": "3.1.4",
      "glob@10.5.0>minimatch": "9.0.7",
      "immutable": "5.1.5",
      "jest-message-util>picomatch": "4.0.4",
      "jest-util>picomatch": "4.0.4",
      "lodash-es": "4.18.1",
      "minimatch@3.1.4>brace-expansion": "1.1.13",
      "minimatch@3.1.5>brace-expansion": "1.1.13",
      "minimatch@5.1.9>brace-expansion": "2.0.3",
      "minimatch@9.0.7>brace-expansion": "5.0.5",
      "minimatch@9.0.9>brace-expansion": "5.0.5",
      "minimatch@10.2.4>brace-expansion": "5.0.5",
      "mocha>serialize-javascript": "7.0.5",
      "picomatch@4.0.3": "4.0.4",
      "prismjs": "1.30.0",
      "puppeteer-core>ws": "8.20.0",
      "readdirp>picomatch": "2.3.2",
      "recursive-readdir>minimatch": "3.1.4",
      "rollup": "4.60.2",
      "tar-fs": "3.1.2",
      "vite": "7.3.2",
      "yaml": "2.8.3"
    }
  },
  "dependencies": {
    "pnpm": "^10.32.1",
    "pptxgenjs": "^4.0.1"
  }
}
